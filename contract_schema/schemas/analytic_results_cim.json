{
    "title": "Analytic Results CIM",
    "description": "Common Information Model for analytic results in tabular storage. One row represents one analytic finding tied to one MITRE ATT&CK tactic-technique hypothesis for one analytic run, observation window, and primary entity. Multi-technique findings emit one row per technique; multi-entity findings select a primary entity and place supporting entities in entity-evidence fields.",
    "version": "1.4.0",
    "input": {
        "title": "Analytic Results CIM Input Schema",
        "type": "object",
        "description": "Parameters describing how a CIM-conformant result set was produced. These mirror the standard analytic_schema inputs so that any analytic emitting CIM rows can validate its own runtime configuration.",
        "fields": {
            "start_dtg": {
                "type": ["string"],
                "required": true,
                "format": "date-time",
                "description": "Inclusive UTC timestamp (ISO 8601) marking the first data element evaluated."
            },
            "end_dtg": {
                "type": ["string"],
                "required": true,
                "format": "date-time",
                "description": "Exclusive UTC timestamp (ISO 8601) marking the end of the data window."
            },
            "data_source_type": {
                "type": ["string"],
                "required": true,
                "enum": ["file", "IONIC", "api"],
                "description": "Transport mechanism used to retrieve data for the run."
            },
            "data_source": {
                "type": ["string"],
                "required": true,
                "description": "Path, identifier, or URL the runner used to fetch the dataset."
            },
            "log_path": {
                "type": ["string"],
                "required": false,
                "default": "stdout",
                "description": "Filesystem path or stream for execution logs. Default 'stdout'."
            },
            "output": {
                "type": ["string"],
                "required": false,
                "default": "stdout",
                "description": "Destination for the CIM results document. Supports 'stdout' or a file path."
            },
            "analytic_parameters": {
                "type": ["object", "string"],
                "required": false,
                "default": {},
                "description": "Arbitrary JSON object or path to JSON file containing analytic-specific tuning knobs."
            },
            "verbosity": {
                "type": ["string"],
                "required": false,
                "enum": ["DEBUG", "INFO", "WARN", "ERROR", "FATAL"],
                "default": "INFO",
                "description": "Lowest log-severity level that will be emitted (default INFO)."
            }
        },
        "additionalProperties": true
    },
    "output": {
        "title": "Analytic Results CIM Output Schema",
        "type": "object",
        "description": "Wrapper document containing one or more CIM result rows along with run-scoped metadata. The 'results' list is the canonical CIM payload; everything else is provenance, audit, and execution context.",
        "fields": {
            "cim_schema_name": {
                "type": ["string"],
                "required": true,
                "enum": ["analytic_results_cim"],
                "description": "Stable identifier for this CIM. Allows downstream consumers to dispatch on schema family."
            },
            "cim_schema_version": {
                "type": ["string"],
                "required": true,
                "pattern": "^\\d+\\.\\d+\\.\\d+$",
                "description": "Semantic version of the CIM row schema embedded in this document."
            },
            "input_schema_version": {
                "type": ["string"],
                "required": true,
                "description": "Echo of the input contract version used for this run."
            },
            "output_schema_version": {
                "type": ["string"],
                "required": true,
                "description": "Semantic-version identifier for this output contract."
            },
            "initialization_dtg": {
                "type": ["string"],
                "required": true,
                "format": "date-time",
                "description": "UTC timestamp (ISO-8601) when the document was instantiated."
            },
            "finalization_dtg": {
                "type": ["string"],
                "required": true,
                "format": "date-time",
                "description": "UTC timestamp (ISO-8601) when finalise() completed."
            },
            "total_runtime_seconds": {
                "type": ["integer"],
                "required": true,
                "description": "Elapsed seconds between initialization_dtg and finalization_dtg."
            },
            "run_id": {
                "type": ["string"],
                "required": true,
                "description": "Globally unique identifier (UUID v4 recommended) assigned at run start. Equivalent to analytic_run_id on each row."
            },
            "execution_environment": {
                "type": ["object"],
                "required": true,
                "description": "Software and hardware context in which the analytic ran.",
                "fields": {
                    "python_version": {
                        "type": ["string"],
                        "required": true,
                        "description": "Exact Python interpreter version."
                    },
                    "library_dependencies": {
                        "type": ["object"],
                        "required": true,
                        "description": "Map of critical libraries with exact versions."
                    },
                    "operating_system": {
                        "type": ["string"],
                        "required": true,
                        "description": "OS name and version the analytic ran on."
                    },
                    "username": {
                        "type": ["string"],
                        "required": true,
                        "description": "User account that executed the analytic."
                    },
                    "hardware_specs": {
                        "type": ["object"],
                        "required": true,
                        "description": "Key hardware details (CPU, GPU, RAM).",
                        "fields": {
                            "cpu": {"type": ["string"], "required": true, "description": "CPU model."},
                            "gpu": {"type": ["string"], "required": false, "description": "GPU model, if applicable."},
                            "ram": {"type": ["string"], "required": true, "description": "Total system RAM."}
                        },
                        "additionalProperties": false
                    }
                },
                "additionalProperties": false
            },
            "author": {"type": ["string"], "required": true, "description": "Primary author."},
            "author_organization": {"type": ["string"], "required": true, "description": "Author's organization at the time of execution."},
            "contact": {"type": ["string"], "required": true, "description": "Email or link for questions and comments."},
            "license": {"type": ["string"], "required": true, "description": "Software license under which the code or outputs are released."},
            "documentation_link": {"type": ["string"], "required": true, "description": "URL to a paper, blog post, or other resource for more information."},
            "status": {
                "type": ["string"],
                "required": true,
                "enum": ["success", "fail", "warning", "UNKNOWN"],
                "description": "High-level execution outcome."
            },
            "exit_code": {"type": ["integer"], "required": true, "description": "Process exit status (0 = success)."},
            "messages": {
                "type": ["list"],
                "required": false,
                "description": "Ordered log entries generated during execution.",
                "items": {
                    "fields": {
                        "timestamp": {"type": ["string"], "format": "date-time", "required": true},
                        "level": {"type": ["string"], "enum": ["DEBUG", "INFO", "WARN", "ERROR", "FATAL"], "required": true},
                        "text": {"type": ["string"], "required": true}
                    },
                    "additionalProperties": false
                }
            },
            "inputs": {"type": ["object"], "required": true, "description": "Verbatim copy of the input parameter object for auditability."},
            "input_hash": {"type": ["string"], "required": true, "description": "SHA-256 hash of the canonicalised inputs object."},
            "results": {
                "type": ["list"],
                "required": true,
                "description": "Ordered list of CIM result rows emitted by this run. Row grain: analytic_run_id + result_id + observation_window + primary_entity + tactic_id + technique_id.",
                "items": {
                    "type": ["object"],
                    "fields": {
                        "result_id": {
                            "type": ["string"],
                            "required": true,
                            "description": "Globally unique ID for this result row. Prefer a deterministic hash of run ID, analytic, entity, time window, and technique."
                        },
                        "analytic_run_id": {
                            "type": ["string"],
                            "required": true,
                            "description": "Unique ID for one execution of the analytic. Matches the document-level run_id."
                        },
                        "dtg_utc": {
                            "type": ["string"],
                            "required": true,
                            "format": "date-time",
                            "description": "Time the result was produced, ISO-8601 UTC."
                        },
                        "observation_start_utc": {
                            "type": ["string"],
                            "required": true,
                            "format": "date-time",
                            "description": "Start of the data window evaluated."
                        },
                        "observation_end_utc": {
                            "type": ["string"],
                            "required": true,
                            "format": "date-time",
                            "description": "End of the data window evaluated."
                        },
                        "run_username": {
                            "type": ["string"],
                            "required": true,
                            "description": "Username of the person or service account that ran the analytic."
                        },
                        "analytic_id": {
                            "type": ["string"],
                            "required": true,
                            "description": "Stable unique analytic identifier independent of file path."
                        },
                        "analytic_name": {
                            "type": ["string"],
                            "required": true,
                            "description": "Human-readable analytic name."
                        },
                        "analytic_description": {
                            "type": ["string"],
                            "required": true,
                            "description": "Plain-language description of analytic behavior."
                        },
                        "analytic_path": {
                            "type": ["string", "null"],
                            "required": false,
                            "description": "Repository path to analytic source."
                        },
                        "analytic_url": {
                            "type": ["string", "null"],
                            "required": false,
                            "description": "URL to analytic source or rendered analytic page."
                        },
                        "analytic_repo_url": {
                            "type": ["string", "null"],
                            "required": false,
                            "description": "Repository URL."
                        },
                        "analytic_branch": {
                            "type": ["string", "null"],
                            "required": false,
                            "description": "Git branch used at execution."
                        },
                        "analytic_commit_hash": {
                            "type": ["string", "null"],
                            "required": false,
                            "description": "Git commit used for execution."
                        },
                        "analytic_version": {
                            "type": ["string"],
                            "required": true,
                            "description": "Semantic version, release tag, or internal version."
                        },
                        "analytic_config_hash": {
                            "type": ["string", "null"],
                            "required": false,
                            "description": "Hash of analytic configuration or parameters."
                        },
                        "analytic_engine": {
                            "type": ["string", "null"],
                            "required": false,
                            "description": "Execution engine or framework."
                        },
                        "input_dataset_names": {
                            "type": ["list", "null"],
                            "required": false,
                            "description": "Source dataset / table names used by the analytic. Stored as an ARRAY VARCHAR (list of strings) for tabular storage.",
                            "items": {"type": ["string"]}
                        },
                        "mitre_attack_domain": {
                            "type": ["string"],
                            "required": true,
                            "enum": ["enterprise", "mobile", "ics", "cloud"],
                            "description": "ATT&CK domain. Local profiles should map onto one of these values."
                        },
                        "mitre_tactic_id": {
                            "type": ["string"],
                            "required": true,
                            "pattern": "^TA[0-9]{4}$",
                            "description": "ATT&CK tactic ID (e.g., TA0002)."
                        },
                        "mitre_tactic_name": {
                            "type": ["string"],
                            "required": true,
                            "description": "ATT&CK tactic name."
                        },
                        "mitre_technique_id": {
                            "type": ["string"],
                            "required": true,
                            "pattern": "^T[0-9]{4}(\\.[0-9]{3})?$",
                            "description": "ATT&CK technique or sub-technique ID. Store the most specific form (e.g., T1053.005, not T1053)."
                        },
                        "mitre_technique_name": {
                            "type": ["string"],
                            "required": true,
                            "description": "ATT&CK technique name."
                        },
                        "mitre_subtechnique_id": {
                            "type": ["string", "null"],
                            "required": false,
                            "pattern": "^T[0-9]{4}\\.[0-9]{3}$",
                            "description": "Optional explicit sub-technique ID, if separate from mitre_technique_id."
                        },
                        "mitre_subtechnique_name": {
                            "type": ["string", "null"],
                            "required": false,
                            "description": "Optional sub-technique name."
                        },
                        "result_score": {
                            "type": ["number", "null"],
                            "required": false,
                            "description": "Analytic-native score, usually 0.0-1.0."
                        },
                        "result_score_type": {
                            "type": ["string", "null"],
                            "required": false,
                            "enum": ["probability", "risk_score", "z_score", "rule_score", "distance", "rank", null],
                            "description": "Interpretation of result_score."
                        },
                        "result_threshold": {
                            "type": ["number", "null"],
                            "required": false,
                            "description": "Threshold used to produce this result."
                        },
                        "result_severity": {
                            "type": ["string"],
                            "required": true,
                            "enum": ["informational", "low", "medium", "high", "critical"],
                            "description": "Analyst-assessed severity."
                        },
                        "behavior_likelihood": {
                            "type": ["string"],
                            "required": true,
                            "enum": ["unlikely", "possible", "likely", "highly_likely"],
                            "description": "How likely the behavior is malicious."
                        },
                        "analytic_confidence": {
                            "type": ["string"],
                            "required": true,
                            "enum": ["low", "moderate", "high"],
                            "description": "Sufficiency of method/evidence. Distinct from behavior_likelihood: a result can be highly suspicious but low confidence because logs are incomplete."
                        },
                        "environment_domain": {
                            "type": ["string"],
                            "required": true,
                            "enum": ["host", "network", "cloud", "identity", "ot", "container", "hybrid"],
                            "description": "Primary environment type."
                        },
                        "site_name": {
                            "type": ["string", "null"],
                            "required": false,
                            "description": "Physical or logical site."
                        },
                        "datasource_vendor": {
                            "type": ["string", "null"],
                            "required": false,
                            "description": "Vendor or platform."
                        },
                        "datasource_product": {
                            "type": ["string", "null"],
                            "required": false,
                            "description": "Product or service."
                        },
                        "log_source_type": {
                            "type": ["string", "null"],
                            "required": false,
                            "enum": ["endpoint", "network", "identity", "cloud_control_plane", "ot_telemetry", null],
                            "description": "Normalized log source type."
                        },
                        "primary_entity_type": {
                            "type": ["string"],
                            "required": true,
                            "enum": ["user", "host", "process", "ip", "domain", "cloud_principal", "cloud_resource", "ot_asset", "container"],
                            "description": "Main subject of the result. Indicates which sub-object under the row's `results` field is the primary subject; the other typed buckets (when present) describe supporting context."
                        },
                        "results": {
                            "type": ["object"],
                            "required": true,
                            "description": "Typed observation buckets for this finding. Populate one or more of `host`, `net`, `cloud`, `ot` with the entity / observation fields for that domain. Buckets that do not apply MUST be omitted (or set to null) so `results_count` reflects how many domains the finding actually touched.",
                            "fields": {
                                "host": {
                                    "type": ["object", "null"],
                                    "required": false,
                                    "description": "Host-domain observation: hostname / IP / user plus the process information the analytic produced (process name, path, hash, command line, parent process).",
                                    "fields": {
                                        "_timestamp":            {"type": ["string", "null"],  "required": false, "description": "Event timestamp for this observation (ISO-8601 UTC when present)."},
                                        "hostname":              {"type": ["string", "null"],  "required": false, "description": "Hostname or FQDN of the affected host."},
                                        "ip":                    {"type": ["string", "null"],  "required": false, "description": "IP of the affected host, if known."},
                                        "user":                  {"type": ["string", "null"],  "required": false, "description": "User account associated with the finding on the host."},
                                        "process_name":          {"type": ["string", "null"],  "required": false, "description": "Process basename observed by the analytic (e.g. 'schtasks.exe')."},
                                        "process_path":          {"type": ["string", "null"],  "required": false, "description": "Full image path of the observed process."},
                                        "process_hash":          {"type": ["string", "null"],  "required": false, "description": "File hash of the observed process, preferably SHA-256."},
                                        "process_id":            {"type": ["integer", "null"], "required": false, "description": "OS process identifier."},
                                        "process_guid":          {"type": ["string", "null"],  "required": false, "description": "Stable process identifier (e.g. Sysmon ProcessGuid)."},
                                        "process_command_line":  {"type": ["string", "null"],  "required": false, "description": "Command line used to invoke the observed process."},
                                        "parent_process_name":   {"type": ["string", "null"],  "required": false, "description": "Parent process basename."},
                                        "parent_process_path":   {"type": ["string", "null"],  "required": false, "description": "Parent process image path."},
                                        "parent_process_id":     {"type": ["integer", "null"], "required": false, "description": "Parent process identifier."},
                                        "target_process_name":   {"type": ["string", "null"],  "required": false, "description": "Target process basename for cross-process analytics (e.g. lsass.exe in T1003.001)."},
                                        "target_process_path":   {"type": ["string", "null"],  "required": false, "description": "Target process image path for cross-process analytics."},
                                        "target_process_id":     {"type": ["integer", "null"], "required": false, "description": "Target process identifier for cross-process analytics."}
                                    },
                                    "additionalProperties": false
                                },
                                "net": {
                                    "type": ["object", "null"],
                                    "required": false,
                                    "description": "Network-domain observation: source/destination addressing, transport, and application service.",
                                    "fields": {
                                        "_timestamp":   {"type": ["string", "null"],  "required": false, "description": "Event timestamp for this observation (ISO-8601 UTC when present)."},
                                        "src_ip":       {"type": ["string", "null"],  "required": false, "description": "Source IP."},
                                        "src_port":     {"type": ["integer", "null"], "required": false, "description": "Source port."},
                                        "src_hostname": {"type": ["string", "null"],  "required": false, "description": "Source hostname."},
                                        "src_user":     {"type": ["string", "null"],  "required": false, "description": "Source user/principal."},
                                        "dst_ip":       {"type": ["string", "null"],  "required": false, "description": "Destination IP."},
                                        "dst_port":     {"type": ["integer", "null"], "required": false, "description": "Destination port."},
                                        "dst_hostname": {"type": ["string", "null"],  "required": false, "description": "Destination hostname."},
                                        "dst_domain":   {"type": ["string", "null"],  "required": false, "description": "Queried or contacted domain."},
                                        "dst_url":      {"type": ["string", "null"],  "required": false, "description": "URL, if applicable."},
                                        "protocol":     {"type": ["string", "null"],  "required": false, "description": "Network or application protocol."},
                                        "service_name": {"type": ["string", "null"],  "required": false, "description": "Service or application protocol name."}
                                    },
                                    "additionalProperties": false
                                },
                                "cloud": {
                                    "type": ["object", "null"],
                                    "required": false,
                                    "description": "Cloud-domain observation: provider, account/tenant, principal, resource, and API action.",
                                    "fields": {
                                        "_timestamp":     {"type": ["string", "null"], "required": false, "description": "Event timestamp for this observation (ISO-8601 UTC when present)."},
                                        "provider":       {"type": ["string", "null"], "required": false, "description": "Cloud provider (e.g., aws, azure, gcp, oci)."},
                                        "account_id":     {"type": ["string", "null"], "required": false, "description": "Account / subscription / project ID."},
                                        "tenant_id":      {"type": ["string", "null"], "required": false, "description": "Cloud or SaaS tenant ID."},
                                        "principal_id":   {"type": ["string", "null"], "required": false, "description": "Cloud principal / user / role ID."},
                                        "principal_name": {"type": ["string", "null"], "required": false, "description": "Cloud principal name."},
                                        "resource_id":    {"type": ["string", "null"], "required": false, "description": "Cloud resource identifier."},
                                        "resource_type":  {"type": ["string", "null"], "required": false, "description": "VM, bucket, key vault, IAM role, etc."},
                                        "api_action":     {"type": ["string", "null"], "required": false, "description": "Cloud API action invoked."}
                                    },
                                    "additionalProperties": false
                                },
                                "ot": {
                                    "type": ["object", "null"],
                                    "required": false,
                                    "description": "Operational-technology observation: ICS asset, protocol, and function code.",
                                    "fields": {
                                        "_timestamp":    {"type": ["string", "null"], "required": false, "description": "Event timestamp for this observation (ISO-8601 UTC when present)."},
                                        "asset_id":      {"type": ["string", "null"], "required": false, "description": "OT asset identifier."},
                                        "asset_type":    {"type": ["string", "null"], "required": false, "description": "PLC, HMI, engineering workstation, historian, RTU, sensor, etc."},
                                        "protocol":      {"type": ["string", "null"], "required": false, "description": "Modbus, DNP3, S7, OPC UA, EtherNet/IP, etc."},
                                        "function_code": {"type": ["string", "null"], "required": false, "description": "OT/ICS function code or command."}
                                    },
                                    "additionalProperties": false
                                }
                            },
                            "additionalProperties": false
                        },
                        "result_count": {
                            "type": ["integer", "null"],
                            "required": false,
                            "description": "Total number of result rows emitted by the analytic for this run."
                        }
                    },
                    "additionalProperties": false
                }
            },
            "results_hash": {
                "type": ["string"],
                "required": true,
                "description": "SHA-256 (or stronger) hash of the serialised results array."
            },
            "additional_run_properties": {
                "type": ["object"],
                "required": false,
                "description": "Arbitrary, user-supplied key-value metadata that applies to the entire run.",
                "additionalProperties": true
            }
        },
        "additionalProperties": false
    }
}
