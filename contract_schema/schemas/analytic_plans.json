{
  "title": "Analytic Plans Contract",
  "description": "Schema contract for MITRE ATT&CK and D3FEND analytic plan documents stored as JSON arrays.",
  "version": "1.0.0",
  "input": {
    "title": "Analytic Plans Input Schema",
    "type": "object",
    "description": "Wrapper object used to validate raw analytic plan arrays from the techniques directory.",
    "fields": {
      "analytic_plans": {
        "type": ["list"],
        "required": true,
        "minItems": 1,
        "description": "A list of analytic plan entries.",
        "items": {
          "type": ["object"],
          "fields": {
            "information_requirement": {
              "type": ["string"],
              "required": true,
              "minLength": 1,
              "pattern": ".+\\?(?:\\s+\\([^)]+\\))*$",
              "description": "Mission question or CCIR phrased as a question."
            },
            "tactic_id": {
              "type": ["string"],
              "required": true,
              "pattern": "(?:TA\\d{4}|D3-[A-Z0-9]+)",
              "description": "MITRE ATT&CK tactic ID or D3FEND tactic identifier."
            },
            "tactic_name": {
              "type": ["string"],
              "required": true,
              "minLength": 1,
              "description": "MITRE tactic name."
            },
            "tactic_description": {
              "type": ["string"],
              "required": true,
              "minLength": 1,
              "description": "MITRE tactic description."
            },
            "tactic_url": {
              "type": ["string"],
              "required": true,
              "pattern": "https?://.+",
              "description": "ATT&CK or D3FEND tactic URL."
            },
            "tactic_created": {
              "type": ["string"],
              "required": true,
              "format": "mitre-date-time",
              "description": "MITRE tactic creation timestamp."
            },
            "tactic_last_modified": {
              "type": ["string"],
              "required": true,
              "format": "mitre-date-time",
              "description": "MITRE tactic last-modified timestamp."
            },
            "tactic_domain": {
              "type": ["list"],
              "required": true,
              "minItems": 1,
              "items": {
                "type": ["string"],
                "minLength": 1
              },
              "description": "MITRE tactic domains."
            },
            "tactic_version": {
              "type": ["string"],
              "required": true,
              "pattern": "\\d+(?:\\.\\d+)+",
              "description": "MITRE tactic version string."
            },
            "indicators": {
              "type": ["list"],
              "required": true,
              "minItems": 1,
              "description": "Indicators associated with the information requirement.",
              "items": {
                "type": ["object"],
                "fields": {
                  "technique_id": {
                    "type": ["string"],
                    "required": true,
                    "pattern": "(?:T\\d{4}(?:\\.\\d{3})?|D3-[A-Z0-9]+)",
                    "description": "MITRE ATT&CK technique ID or D3FEND technique identifier."
                  },
                  "technique_name": {
                    "type": ["string"],
                    "required": true,
                    "minLength": 1,
                    "description": "MITRE technique name."
                  },
                  "technique_description": {
                    "type": ["string"],
                    "required": true,
                    "minLength": 1,
                    "description": "MITRE technique description."
                  },
                  "technique_url": {
                    "type": ["string"],
                    "required": true,
                    "pattern": "https?://.+",
                    "description": "ATT&CK or D3FEND technique URL."
                  },
                  "technique_created": {
                    "type": ["string"],
                    "required": true,
                    "format": "mitre-date-time",
                    "description": "MITRE technique creation timestamp."
                  },
                  "technique_last_modified": {
                    "type": ["string"],
                    "required": true,
                    "format": "mitre-date-time",
                    "description": "MITRE technique last-modified timestamp."
                  },
                  "technique_domain": {
                    "type": ["list"],
                    "required": true,
                    "minItems": 1,
                    "items": {
                      "type": ["string"],
                      "minLength": 1
                    },
                    "description": "MITRE technique domains."
                  },
                  "technique_version": {
                    "type": ["string"],
                    "required": true,
                    "pattern": "\\d+(?:\\.\\d+)+",
                    "description": "MITRE technique version string."
                  },
                  "technique_platforms": {
                    "type": ["list"],
                    "required": true,
                    "minItems": 1,
                    "items": {
                      "type": ["string"],
                      "minLength": 1
                    },
                    "description": "Platforms associated with the technique."
                  },
                  "technique_analytics": {
                    "type": ["object"],
                    "required": true,
                    "minProperties": 1,
                    "propertyNamesPattern": "AN\\d{4}",
                    "description": "MITRE analytics keyed by analytic identifier.",
                    "additionalProperties": {
                      "type": ["object"],
                      "fields": {
                        "analytic_name": {
                          "type": ["string"],
                          "required": true,
                          "minLength": 1
                        },
                        "analytic_description": {
                          "type": ["string"],
                          "required": true,
                          "minLength": 1
                        },
                        "analytic_url": {
                          "type": ["string"],
                          "required": true,
                          "pattern": "https?://.+"
                        },
                        "analytic_created": {
                          "type": ["string"],
                          "required": true,
                          "format": "mitre-date-time"
                        },
                        "analytic_last_modified": {
                          "type": ["string"],
                          "required": true,
                          "format": "mitre-date-time"
                        },
