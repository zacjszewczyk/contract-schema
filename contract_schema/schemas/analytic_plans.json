                        },
                        "analytic_log_source_references": {
                          "type": ["list"],
                          "required": true,
                          "minItems": 1,
                          "items": {
                            "type": ["object"],
                            "fields": {
                              "data_component_id": {
                                "type": ["string"],
                                "required": true,
                                "pattern": "DC\\d{4}"
                              },
                              "data_component_title": {
                                "type": ["string"],
                                "required": true,
                                "minLength": 1
                              },
                              "log_source_name": {
                                "type": ["string"],
                                "required": true,
                                "minLength": 1
                              },
                              "log_source_channel": {
                                "type": ["string"],
                                "required": true,
                                "minLength": 1
                              }
                            },
                            "additionalProperties": false
                          }
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "detection_strategies": {
                    "type": ["object"],
                    "required": true,
                    "minProperties": 1,
                    "propertyNamesPattern": "DET\\d{4}",
                    "description": "MITRE detection strategies keyed by detection strategy identifier.",
                    "additionalProperties": {
                      "type": ["object"],
                      "fields": {
                        "detection_strategy_name": {
                          "type": ["string"],
                          "required": true,
                          "minLength": 1
                        },
                        "detection_strategy_url": {
                          "type": ["string"],
                          "required": true,
                          "pattern": "https?://.+"
                        },
                        "detection_strategy_created": {
                          "type": ["string"],
                          "required": true,
                          "format": "mitre-date-time"
                        },
                        "detection_strategy_last_modified": {
                          "type": ["string"],
                          "required": true,
                          "format": "mitre-date-time"
                        },
                        "detection_strategy_domain": {
                          "type": ["list"],
                          "required": true,
                          "minItems": 1,
                          "items": {
                            "type": ["string"],
                            "minLength": 1
                          }
                        },
                        "detection_strategy_version": {
                          "type": ["string"],
                          "required": true,
                          "pattern": "\\d+(?:\\.\\d+)+"
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "evidence": {
                    "type": ["list"],
                    "required": true,
                    "minItems": 1,
                    "items": {
                      "type": ["object"],
                      "fields": {
                        "description": {
                          "type": ["string"],
                          "required": true,
                          "minLength": 1
                        },
                        "data_sources": {
                          "type": ["list"],
                          "required": true,
                          "minItems": 1,
                          "items": {
                            "type": ["string"],
                            "minLength": 1
                          }
                        },
                        "data_platforms": {
                          "type": ["list"],
                          "required": true,
                          "minItems": 1,
                          "items": {
                            "type": ["string"],
                            "pattern": "TBD"
                          }
                        },
                        "nai": {
                          "type": ["string"],
                          "required": true,
                          "minLength": 1
                        },
                        "action": {
                          "type": ["object"],
                          "required": true,
                          "minProperties": 1,
                          "propertyNamesPattern": ".+",
                          "additionalProperties": {
                            "type": ["string"],
                            "minLength": 1,
                            "pattern": "(?:Symbolic Logic|Statistical Method|Machine Learning):\\s.+"
                          }
                        }
                      },
                      "additionalProperties": false
                    }
                  }
                },
                "additionalProperties": false
              }
            },
            "last_updated": {
              "type": ["string"],
              "required": true,
              "format": "date",
              "description": "Date the analytic plan was last updated."
            },
            "version": {
              "type": ["string"],
              "required": true,
              "pattern": "\\d+(?:\\.\\d+)+",
              "description": "Analytic plan version string."
            },
            "date_created": {
              "type": ["string"],
              "required": true,
              "format": "date",
              "description": "Date the analytic plan was created."
            },
            "contributors": {
              "type": ["list"],
              "required": true,
              "minItems": 1,
              "items": {
                "type": ["string"],
                "minLength": 1
              },
              "description": "Contributors to the analytic plan."
            }
          },
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
  },
